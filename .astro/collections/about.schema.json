{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "meta_title": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "what_i_do": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "description"
            ]
          }
        }
      },
      "required": [
        "title",
        "items"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "what_i_do"
  ]
}